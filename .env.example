# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edurinconai"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# LLM API Configuration (LM Studio / OpenAI Compatible)
LLM_API_BASE_URL="http://localhost:1234/v1"
LLM_API_KEY="lm-studio"
LLM_MODEL_NAME="llama3.2"
LLM_EMBEDDING_MODEL="text-embedding-nomic-embed-text-v1.5"

# Timeouts para modelos grandes (deepseek-r1:32b, etc.) - en milisegundos
# LLM_HEADERS_TIMEOUT_MS=120000  # 2 min - tiempo para recibir headers
# LLM_BODY_TIMEOUT_MS=300000    # 5 min - tiempo para streaming

# File Upload Configuration
MAX_FILE_SIZE_MB=10
UPLOAD_DIR="./uploads"

# Application Configuration
NODE_ENV="development"
