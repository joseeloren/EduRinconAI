# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edurinconai"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# LLM API Configuration (Ollama/LocalAI)
LLM_API_BASE_URL="http://your-vdi-ip:11434/v1"
LLM_MODEL_NAME="llama3.2"
LLM_EMBEDDING_MODEL="nomic-embed-text"

# File Upload Configuration
MAX_FILE_SIZE_MB=10
UPLOAD_DIR="./uploads"

# Application Configuration
NODE_ENV="development"
